@{
    ViewData["Title"] = "Hafta 7 - Bootstrap ve JavaScript";
}

@section Styles {
    <link rel="stylesheet" href="~/styles/hafta7.css" asp-append-version="true" />
}

<header id="anasayfa" class="hero-section">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-7">
                <span class="badge text-bg-primary px-3 py-2 mb-4">Hafta 7 Laboratuvarı</span>
                <h1 class="display-3 fw-bold lh-sm mb-4">Bootstrap ve JavaScript ile Etkinlik Kayıt Sayfası</h1>
                <p class="fs-4 text-secondary mb-4">
                    Bu sayfada Bootstrap ile responsive bir arayüz tasarlanır; JavaScript ile de
                    tema değiştirme ve form verilerinden başvuru özeti üretme işlemleri yapılır.
                </p>
                <div class="d-flex flex-column flex-sm-row gap-3">
                    <a class="btn btn-primary btn-lg px-4 py-3" href="#basvuru">Başvuru Formuna Git</a>
                    <button id="temaButonu" class="btn btn-outline-dark btn-lg px-4 py-3" type="button">
                        Koyu Temaya Geç
                    </button>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="card feature-card border-0 shadow-lg rounded-4">
                    <div class="card-body p-4 p-lg-5">
                        <h2 class="h1 fw-bold mb-3">Neler Kullanıldı?</h2>
                        <div class="d-flex flex-wrap gap-2 mb-4">
                            <span class="badge rounded-pill text-bg-dark">Navbar</span>
                            <span class="badge rounded-pill text-bg-primary">Grid</span>
                            <span class="badge rounded-pill text-bg-success">Card</span>
                            <span class="badge rounded-pill text-bg-warning text-dark">Form</span>
                            <span class="badge rounded-pill text-bg-info text-dark">Alert</span>
                        </div>
                        <ul class="list-group list-group-flush fs-5">
                            <li class="list-group-item px-0">Bootstrap CDN kullanımı</li>
                            <li class="list-group-item px-0">Responsive sütun yapısı</li>
                            <li class="list-group-item px-0">JavaScript ile form verisi okuma</li>
                            <li class="list-group-item px-0">Tema değiştirme işlemi</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</header>

<main>
    <section id="atolyeler" class="py-5">
        <div class="container">
            <div class="text-center mb-5">
                <h2 class="display-6 fw-bold">Atölye İçerikleri</h2>
                <p class="fs-5 text-secondary">Bootstrap bileşenlerini kullanarak tasarlanmış örnek kartlar</p>
            </div>

            <div class="row g-4">
                <div class="col-md-6 col-lg-4">
                    <article class="card lab-card h-100 border-0 shadow-sm rounded-4">
                        <div class="card-body p-4">
                            <span class="badge text-bg-primary mb-4">01</span>
                            <h3 class="h3 fw-bold mb-3">Responsive Tasarım</h3>
                            <p class="fs-5 text-secondary">
                                Container, row, col yapıları ile farklı ekranlarda uyumlu görünüm oluşturulur.
                            </p>
                            <a class="btn btn-outline-primary mt-2" href="#anasayfa">Detay</a>
                        </div>
                    </article>
                </div>
                <!-- ... other cards ... -->
            </div>
        </div>
    </section>

    <!-- ... rest of the content ... -->
    
    <section id="basvuru" class="form-section py-5">
        <div class="container">
            <div class="card form-card border-0 shadow rounded-4 mx-auto">
                <div class="card-body p-4 p-lg-5">
                    <form id="basvuruFormu" novalidate>
                        <!-- form content -->
                        <div class="row g-4">
                             <div class="col-md-6">
                                <label for="adSoyad" class="form-label fs-5">Ad Soyad</label>
                                <input id="adSoyad" name="adSoyad" type="text" class="form-control form-control-lg" placeholder="Adınızı ve soyadınızı yazın" required>
                            </div>
                            <!-- ... -->
                            <div class="col-12 d-flex flex-column flex-sm-row gap-3">
                                <button class="btn btn-primary btn-lg px-4" type="submit">Başvuru Özeti Oluştur</button>
                                <button id="temizleButonu" class="btn btn-outline-secondary btn-lg px-4" type="reset">Formu Temizle</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <section id="sonuc" class="result-section pb-5">
        <div class="container">
            <div id="sonucAlani" class="alert alert-info fs-5 mb-0 rounded-4" role="alert">
                Henüz başvuru özeti oluşturulmadı. Formu doldurduktan sonra sonuç burada görünecek.
            </div>
        </div>
    </section>
</main>

@section Scripts {
    <script src="~/scripts/hafta7.js" asp-append-version="true"></script>
}